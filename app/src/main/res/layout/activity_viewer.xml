<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Відео 1 (ліворуч або повний екран) -->
    <TextureView
        android:id="@+id/videoView1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvAlarm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/divider"/>

    <View
        android:id="@+id/divider"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#333333"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvAlarm"
        app:layout_constraintEnd_toStartOf="@+id/videoView2"
        app:layout_constraintStart_toEndOf="@+id/videoView1"/>

    <!-- Відео 2 (праворуч) -->
    <TextureView
        android:id="@+id/videoView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvAlarm"
        app:layout_constraintStart_toEndOf="@+id/divider"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Заглушка коли нема камер -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="📷\n\nНемає підключених камер\n\nНатисни «+ Камера»"
        android:textColor="#88FFFFFF"
        android:textSize="18sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvAlarm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Статус тривоги -->
    <TextView
        android:id="@+id/tvAlarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нема камер"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="14dp"
        android:background="#CC1A1A1A"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"/>

    <!-- Нижня панель -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="+ Камера"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/green_dark"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnTest"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="🔔 Тест"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6D00"
            android:layout_marginHorizontal="3dp"/>

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Відключити"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/red"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
